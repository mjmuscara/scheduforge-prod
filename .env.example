# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get this from: https://dashboard.stripe.com → Developers → API keys
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here

# Stripe price IDs — create these in Stripe Dashboard → Products
REACT_APP_STRIPE_STARTER_PRICE_ID=price_starter_id_here
REACT_APP_STRIPE_GROWTH_PRICE_ID=price_growth_id_here
REACT_APP_STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id_here

# ─── App ────────────────────────────────────────────────────────────────────
REACT_APP_URL=https://app.scheduforge.com
